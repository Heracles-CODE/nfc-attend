  59:../Bsp/NFC/rc522_platform_stm32.c **** /**
  60:../Bsp/NFC/rc522_platform_stm32.c ****  * @brief SPI 全双工字节传输 (软件模拟 SPI Mode 0)
  61:../Bsp/NFC/rc522_platform_stm32.c ****  * @param data 要发送的数据字节
  62:../Bsp/NFC/rc522_platform_stm32.c ****  * @return 接收到的数据字节
  63:../Bsp/NFC/rc522_platform_stm32.c ****  *
  64:../Bsp/NFC/rc522_platform_stm32.c ****  * @note  SPI Mode 0 (CPOL=0, CPHA=0):
  65:../Bsp/NFC/rc522_platform_stm32.c ****  *        - 空闲时 SCK = 低电平
  66:../Bsp/NFC/rc522_platform_stm32.c ****  *        - 数据在 SCK 上升沿发送 (MOSI 更新)
  67:../Bsp/NFC/rc522_platform_stm32.c ****  *        - 数据在 SCK 下降沿接收 (MISO 采样)
  68:../Bsp/NFC/rc522_platform_stm32.c ****  *
  69:../Bsp/NFC/rc522_platform_stm32.c ****  *        时序:
  70:../Bsp/NFC/rc522_platform_stm32.c ****  *        for 8 bits:
  71:../Bsp/NFC/rc522_platform_stm32.c ****  *            SCK = LOW
  72:../Bsp/NFC/rc522_platform_stm32.c ****  *            set MOSI (根据 data 的最高位)
  73:../Bsp/NFC/rc522_platform_stm32.c ****  *            SCK = HIGH
  74:../Bsp/NFC/rc522_platform_stm32.c ****  *            read MISO
  75:../Bsp/NFC/rc522_platform_stm32.c ****  *            data <<= 1
  76:../Bsp/NFC/rc522_platform_stm32.c ****  *            data |= MISO
  77:../Bsp/NFC/rc522_platform_stm32.c ****  *        SCK = LOW (结束状态)
  78:../Bsp/NFC/rc522_platform_stm32.c ****  */
  79:../Bsp/NFC/rc522_platform_stm32.c **** static uint8_t spi_transfer_byte(uint8_t data)
  80:../Bsp/NFC/rc522_platform_stm32.c **** {
  81:../Bsp/NFC/rc522_platform_stm32.c ****     uint8_t rx = 0;
  82:../Bsp/NFC/rc522_platform_stm32.c **** 
  83:../Bsp/NFC/rc522_platform_stm32.c ****     /* 临界区保护：防止任务切换导致 SCK 时序断裂
  84:../Bsp/NFC/rc522_platform_stm32.c ****      * 一个字节传输约 32 µs，临界区长度可接受 */
  85:../Bsp/NFC/rc522_platform_stm32.c ****     taskENTER_CRITICAL();
  86:../Bsp/NFC/rc522_platform_stm32.c **** 
  87:../Bsp/NFC/rc522_platform_stm32.c ****     for (int8_t i = 7; i >= 0; i--) {
  88:../Bsp/NFC/rc522_platform_stm32.c ****         /* SCK 下降沿 -> 拉低 SCK */
  89:../Bsp/NFC/rc522_platform_stm32.c ****         HAL_GPIO_WritePin(NFC_SCK_GPIO_Port, NFC_SCK_Pin, GPIO_PIN_RESET);
  90:../Bsp/NFC/rc522_platform_stm32.c ****         delay_us(1);
  91:../Bsp/NFC/rc522_platform_stm32.c **** 
ARM GAS  C:\Users\fish\AppData\Local\Temp\cc5bu24L.s 			page 5


  92:../Bsp/NFC/rc522_platform_stm32.c ****         /* 设置 MOSI 数据位 (MSB 优先) */
  93:../Bsp/NFC/rc522_platform_stm32.c ****         if (data & 0x80) {
  94:../Bsp/NFC/rc522_platform_stm32.c ****             HAL_GPIO_WritePin(NFC_MOSI_GPIO_Port, NFC_MOSI_Pin, GPIO_PIN_SET);
  95:../Bsp/NFC/rc522_platform_stm32.c ****         } else {
  96:../Bsp/NFC/rc522_platform_stm32.c ****             HAL_GPIO_WritePin(NFC_MOSI_GPIO_Port, NFC_MOSI_Pin, GPIO_PIN_RESET);
  97:../Bsp/NFC/rc522_platform_stm32.c ****         }
  98:../Bsp/NFC/rc522_platform_stm32.c ****         delay_us(1);
  99:../Bsp/NFC/rc522_platform_stm32.c **** 
 100:../Bsp/NFC/rc522_platform_stm32.c ****         /* SCK 上升沿 -> 从机采样 MOSI */
 101:../Bsp/NFC/rc522_platform_stm32.c ****         HAL_GPIO_WritePin(NFC_SCK_GPIO_Port, NFC_SCK_Pin, GPIO_PIN_SET);
 102:../Bsp/NFC/rc522_platform_stm32.c ****         delay_us(1);
 103:../Bsp/NFC/rc522_platform_stm32.c **** 
 104:../Bsp/NFC/rc522_platform_stm32.c ****         /* 在 SCK 高电平时采样 MISO */
 105:../Bsp/NFC/rc522_platform_stm32.c ****         rx <<= 1;
 106:../Bsp/NFC/rc522_platform_stm32.c ****         if (HAL_GPIO_ReadPin(NFC_MISO_GPIO_Port, NFC_MISO_Pin) == GPIO_PIN_SET) {
 107:../Bsp/NFC/rc522_platform_stm32.c ****             rx |= 0x01;
 108:../Bsp/NFC/rc522_platform_stm32.c ****         }
 109:../Bsp/NFC/rc522_platform_stm32.c ****         delay_us(1);
 110:../Bsp/NFC/rc522_platform_stm32.c **** 
 111:../Bsp/NFC/rc522_platform_stm32.c ****         data <<= 1;
 112:../Bsp/NFC/rc522_platform_stm32.c ****     }
 113:../Bsp/NFC/rc522_platform_stm32.c **** 
 114:../Bsp/NFC/rc522_platform_stm32.c ****     /* 结束状态: SCK 回到低电平 */
 115:../Bsp/NFC/rc522_platform_stm32.c ****     HAL_GPIO_WritePin(NFC_SCK_GPIO_Port, NFC_SCK_Pin, GPIO_PIN_RESET);
 116:../Bsp/NFC/rc522_platform_stm32.c ****     delay_us(1);
 117:../Bsp/NFC/rc522_platform_stm32.c **** 
 118:../Bsp/NFC/rc522_platform_stm32.c ****     taskEXIT_CRITICAL();
 119:../Bsp/NFC/rc522_platform_stm32.c **** 
 120:../Bsp/NFC/rc522_platform_stm32.c ****     return rx;
 121:../Bsp/NFC/rc522_platform_stm32.c **** }
