ARM GAS  C:\Users\fish\AppData\Local\Temp\ccIMbRKB.s 			page 13


 658:../Bsp/ESP01/esp01s.c ****     uint16_t len;
 659:../Bsp/ESP01/esp01s.c **** 
 660:../Bsp/ESP01/esp01s.c ****     if (json == NULL || key == NULL || out == NULL || outSize == 0)
 661:../Bsp/ESP01/esp01s.c ****         return NULL;
 662:../Bsp/ESP01/esp01s.c **** 
 663:../Bsp/ESP01/esp01s.c ****     /* ๅๅฎไฝ key,ๅ่ฎธ key ไธ ':' ไน้ดใ':' ไธ value ไน้ดๆ็ฉบๆ ผ */
 664:../Bsp/ESP01/esp01s.c ****     snprintf(pattern, sizeof(pattern), "\"%s\"", key);
 665:../Bsp/ESP01/esp01s.c ****     p = strstr(json, pattern);
 666:../Bsp/ESP01/esp01s.c ****     if (p == NULL)
 667:../Bsp/ESP01/esp01s.c ****         return NULL;
 668:../Bsp/ESP01/esp01s.c **** 
 669:../Bsp/ESP01/esp01s.c ****     p += strlen(pattern);
 670:../Bsp/ESP01/esp01s.c **** 
 671:../Bsp/ESP01/esp01s.c ****     /* ่ทณ่ฟ็ฉบ็ฝ */
 672:../Bsp/ESP01/esp01s.c ****     while (*p == ' ' || *p == '\t' || *p == '\n' || *p == '\r')
 673:../Bsp/ESP01/esp01s.c ****         p++;
 674:../Bsp/ESP01/esp01s.c ****     if (*p != ':')
 675:../Bsp/ESP01/esp01s.c ****         return NULL;
 676:../Bsp/ESP01/esp01s.c ****     p++;
 677:../Bsp/ESP01/esp01s.c ****     while (*p == ' ' || *p == '\t' || *p == '\n' || *p == '\r')
 678:../Bsp/ESP01/esp01s.c ****         p++;
 679:../Bsp/ESP01/esp01s.c **** 
 680:../Bsp/ESP01/esp01s.c ****     if (*p != '"')
 681:../Bsp/ESP01/esp01s.c ****         return NULL;
 682:../Bsp/ESP01/esp01s.c ****     p++;
 683:../Bsp/ESP01/esp01s.c **** 
 684:../Bsp/ESP01/esp01s.c ****     end = strchr(p, '"');
 685:../Bsp/ESP01/esp01s.c ****     if (end == NULL)
 686:../Bsp/ESP01/esp01s.c ****         return NULL;
 687:../Bsp/ESP01/esp01s.c **** 
 688:../Bsp/ESP01/esp01s.c ****     len = (uint16_t)(end - p);
 689:../Bsp/ESP01/esp01s.c ****     if (len >= outSize)
 690:../Bsp/ESP01/esp01s.c ****         len = outSize - 1;
 691:../Bsp/ESP01/esp01s.c **** 
 692:../Bsp/ESP01/esp01s.c ****     memcpy(out, p, len);
 693:../Bsp/ESP01/esp01s.c ****     out[len] = '\0';
 694:../Bsp/ESP01/esp01s.c ****     return out;
 695:../Bsp/ESP01/esp01s.c **** }
