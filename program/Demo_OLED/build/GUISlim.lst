 502:../Bsp/OLED/GUISlim.c **** *       GUI_GetYAdjust
 503:../Bsp/OLED/GUISlim.c **** *
 504:../Bsp/OLED/GUISlim.c **** * Returns adjustment in vertical (Y) direction
 505:../Bsp/OLED/GUISlim.c **** *
 506:../Bsp/OLED/GUISlim.c **** * Note: The return value needs to be subtracted from
 507:../Bsp/OLED/GUISlim.c **** *       the y-position of the character.
 508:../Bsp/OLED/GUISlim.c **** */
 509:../Bsp/OLED/GUISlim.c **** int GUI_GetYAdjust(void) {
 510:../Bsp/OLED/GUISlim.c ****   int r = 0;
 511:../Bsp/OLED/GUISlim.c ****   GUI_LOCK();
 512:../Bsp/OLED/GUISlim.c ****   switch (GUI_Context.TextAlign & GUI_TA_VERTICAL) {
 513:../Bsp/OLED/GUISlim.c **** 	case GUI_TA_BOTTOM:
 514:../Bsp/OLED/GUISlim.c **** 		r = GUI_Context.pAFont->YSize - 1;
 515:../Bsp/OLED/GUISlim.c ****     break;
 516:../Bsp/OLED/GUISlim.c **** 	case GUI_TA_VCENTER:
 517:../Bsp/OLED/GUISlim.c **** 		r = GUI_Context.pAFont->YSize / 2;
 518:../Bsp/OLED/GUISlim.c ****     break;
 519:../Bsp/OLED/GUISlim.c **** 	case GUI_TA_BASELINE:
 520:../Bsp/OLED/GUISlim.c **** 		r = GUI_Context.pAFont->YSize / 2;
 521:../Bsp/OLED/GUISlim.c **** 	}
 522:../Bsp/OLED/GUISlim.c ****   GUI_UNLOCK();
 523:../Bsp/OLED/GUISlim.c ****   return r;
 524:../Bsp/OLED/GUISlim.c **** }
