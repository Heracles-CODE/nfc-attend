 781:../Bsp/OLED/GUISlim.c **** void GUI_DispString(const char GUI_UNI_PTR *s) {
 782:../Bsp/OLED/GUISlim.c ****   int xAdjust, yAdjust, xOrg;
 783:../Bsp/OLED/GUISlim.c ****   int FontSizeY;
 784:../Bsp/OLED/GUISlim.c ****   if (!s)
 785:../Bsp/OLED/GUISlim.c ****     return;
 786:../Bsp/OLED/GUISlim.c ****   GUI_LOCK();
 787:../Bsp/OLED/GUISlim.c ****   FontSizeY = GUI_GetFontDistY();
 788:../Bsp/OLED/GUISlim.c ****   xOrg = GUI_Context.DispPosX;
 789:../Bsp/OLED/GUISlim.c ****  /* Adjust vertical position */
 790:../Bsp/OLED/GUISlim.c ****   yAdjust = GUI_GetYAdjust();
 791:../Bsp/OLED/GUISlim.c ****   GUI_Context.DispPosY -= yAdjust;
 792:../Bsp/OLED/GUISlim.c ****   char *ss = (char *)s;
 793:../Bsp/OLED/GUISlim.c ****   int butf8 = detect_encoding_by_sequence(s);
 794:../Bsp/OLED/GUISlim.c ****   if (butf8 == 1)
 795:../Bsp/OLED/GUISlim.c **** 	  ss = utf8_string_to_gbk_with_table(s);
 796:../Bsp/OLED/GUISlim.c ****   else if (butf8 == 3)
 797:../Bsp/OLED/GUISlim.c **** 	  ss = mixed_string_to_gbk(s);
 798:../Bsp/OLED/GUISlim.c ****   if (!ss)
ARM GAS  C:\Users\fish\AppData\Local\Temp\ccumVi9z.s 			page 97


 799:../Bsp/OLED/GUISlim.c **** 	  return;
 800:../Bsp/OLED/GUISlim.c ****   for (; *ss; ss++) {
 801:../Bsp/OLED/GUISlim.c ****     GUI_RECT r;
 802:../Bsp/OLED/GUISlim.c ****     int LineNumChars = GUI__GetLineNumChars(ss, 0x7fff);
 803:../Bsp/OLED/GUISlim.c ****     int xLineSize    = GUI__GetLineDistX(ss, LineNumChars);
 804:../Bsp/OLED/GUISlim.c ****   /* Check if x-position needs to be changed due to h-alignment */
 805:../Bsp/OLED/GUISlim.c ****     switch (GUI_Context.TextAlign & GUI_TA_HORIZONTAL) { 
 806:../Bsp/OLED/GUISlim.c ****       case GUI_TA_CENTER: xAdjust = xLineSize / 2; break;
 807:../Bsp/OLED/GUISlim.c ****       case GUI_TA_RIGHT:  xAdjust = xLineSize; break;
 808:../Bsp/OLED/GUISlim.c ****       default:            xAdjust = 0;
 809:../Bsp/OLED/GUISlim.c ****     }
 810:../Bsp/OLED/GUISlim.c ****     r.x0 = GUI_Context.DispPosX -= xAdjust;
 811:../Bsp/OLED/GUISlim.c ****     r.x1 = r.x0 + xLineSize - 1;    
 812:../Bsp/OLED/GUISlim.c ****     r.y0 = GUI_Context.DispPosY;
 813:../Bsp/OLED/GUISlim.c ****     r.y1 = r.y0 + FontSizeY - 1;    
 814:../Bsp/OLED/GUISlim.c ****     GUI__DispLine(ss, LineNumChars, &r);
 815:../Bsp/OLED/GUISlim.c ****     GUI_Context.DispPosY = r.y0;
 816:../Bsp/OLED/GUISlim.c ****     ss += GUI_UC__NumChars2NumBytes(ss, LineNumChars);
 817:../Bsp/OLED/GUISlim.c ****     if ((*ss == '\n') || (*ss == '\r')) {
 818:../Bsp/OLED/GUISlim.c ****       switch (GUI_Context.TextAlign & GUI_TA_HORIZONTAL) { 
 819:../Bsp/OLED/GUISlim.c ****       case GUI_TA_CENTER:
 820:../Bsp/OLED/GUISlim.c ****       case GUI_TA_RIGHT:
 821:../Bsp/OLED/GUISlim.c ****         GUI_Context.DispPosX = xOrg;
 822:../Bsp/OLED/GUISlim.c ****         break;
 823:../Bsp/OLED/GUISlim.c ****       default:
 824:../Bsp/OLED/GUISlim.c ****         GUI_Context.DispPosX = 0;
 825:../Bsp/OLED/GUISlim.c ****         break;
 826:../Bsp/OLED/GUISlim.c ****       }
 827:../Bsp/OLED/GUISlim.c ****       if (*ss == '\n')
 828:../Bsp/OLED/GUISlim.c ****         GUI_Context.DispPosY += FontSizeY;
 829:../Bsp/OLED/GUISlim.c ****     } else {
