 144:../Bsp/OLED/GUISlim.c **** int detect_encoding_comprehensive(const char* str) {
 145:../Bsp/OLED/GUISlim.c ****     if (!str) return -1;
 146:../Bsp/OLED/GUISlim.c ****     
 147:../Bsp/OLED/GUISlim.c ****     const unsigned char* s = (const unsigned char*)str;
 148:../Bsp/OLED/GUISlim.c ****     size_t len = strlen((const char*)s);
 149:../Bsp/OLED/GUISlim.c ****     if (len == 0) return 0;
 150:../Bsp/OLED/GUISlim.c ****     
 151:../Bsp/OLED/GUISlim.c ****     EncodingStats stats = {0, 0, 0, 0, 0, 0};
 152:../Bsp/OLED/GUISlim.c ****     int utf8_score = 0;
 153:../Bsp/OLED/GUISlim.c ****     int gbk_score = 0;
 154:../Bsp/OLED/GUISlim.c ****     
 155:../Bsp/OLED/GUISlim.c ****     size_t i = 0;
 156:../Bsp/OLED/GUISlim.c ****     while (i < len) {
 157:../Bsp/OLED/GUISlim.c ****         if (s[i] <= 0x7F) {
 158:../Bsp/OLED/GUISlim.c ****             stats.ascii_count++;
 159:../Bsp/OLED/GUISlim.c ****             i++;
 160:../Bsp/OLED/GUISlim.c ****             continue;
 161:../Bsp/OLED/GUISlim.c ****         }
 162:../Bsp/OLED/GUISlim.c ****         
 163:../Bsp/OLED/GUISlim.c ****         size_t utf8_consumed = 1;
 164:../Bsp/OLED/GUISlim.c ****         size_t gbk_consumed = 1;
ARM GAS  C:\Users\fish\AppData\Local\Temp\ccumVi9z.s 			page 18


 165:../Bsp/OLED/GUISlim.c ****         int is_utf8 = is_valid_utf8_sequence(s + i, len - i, &utf8_consumed);
 166:../Bsp/OLED/GUISlim.c ****         int is_gbk = is_valid_gbk_sequence(s + i, len - i, &gbk_consumed);
 167:../Bsp/OLED/GUISlim.c ****         
 168:../Bsp/OLED/GUISlim.c ****         if (is_utf8 == 1 && is_gbk == 1) {
 169:../Bsp/OLED/GUISlim.c ****                         stats.both_valid++;
 170:../Bsp/OLED/GUISlim.c ****                         int utf8_freq = get_utf8_char_frequency_score(s + i, utf8_consumed);
 171:../Bsp/OLED/GUISlim.c ****             int gbk_freq = get_gbk_char_frequency_score(s + i);
 172:../Bsp/OLED/GUISlim.c ****             utf8_score += utf8_freq;
 173:../Bsp/OLED/GUISlim.c ****             gbk_score += gbk_freq;
 174:../Bsp/OLED/GUISlim.c ****                         if (utf8_consumed == 3 && gbk_consumed == 2) {
 175:../Bsp/OLED/GUISlim.c ****                 utf8_score += 2;             }
 176:../Bsp/OLED/GUISlim.c ****             i += utf8_consumed;
 177:../Bsp/OLED/GUISlim.c ****         }
 178:../Bsp/OLED/GUISlim.c ****         else if (is_utf8 == 1 && is_gbk != 1) {
 179:../Bsp/OLED/GUISlim.c ****                         stats.utf8_only++;
 180:../Bsp/OLED/GUISlim.c ****             utf8_score += 4;             i += utf8_consumed;
 181:../Bsp/OLED/GUISlim.c ****         }
 182:../Bsp/OLED/GUISlim.c ****         else if (is_gbk == 1 && is_utf8 != 1) {
 183:../Bsp/OLED/GUISlim.c ****                         stats.gbk_only++;
 184:../Bsp/OLED/GUISlim.c ****             gbk_score += 4;             i += gbk_consumed;
 185:../Bsp/OLED/GUISlim.c ****         }
 186:../Bsp/OLED/GUISlim.c ****         else if (is_utf8 == 0 && is_gbk == 0) {
 187:../Bsp/OLED/GUISlim.c ****                         stats.utf8_invalid++;
 188:../Bsp/OLED/GUISlim.c ****             stats.gbk_invalid++;
 189:../Bsp/OLED/GUISlim.c ****             i++;
 190:../Bsp/OLED/GUISlim.c ****         }
 191:../Bsp/OLED/GUISlim.c ****         else if (is_utf8 == 0) {
 192:../Bsp/OLED/GUISlim.c ****             stats.utf8_invalid++;
 193:../Bsp/OLED/GUISlim.c ****             i++;
 194:../Bsp/OLED/GUISlim.c ****         }
 195:../Bsp/OLED/GUISlim.c ****         else if (is_gbk == 0) {
 196:../Bsp/OLED/GUISlim.c ****             stats.gbk_invalid++;
 197:../Bsp/OLED/GUISlim.c ****             i++;
 198:../Bsp/OLED/GUISlim.c ****         }
 199:../Bsp/OLED/GUISlim.c ****         else {
 200:../Bsp/OLED/GUISlim.c ****             i++;
 201:../Bsp/OLED/GUISlim.c ****         }
 202:../Bsp/OLED/GUISlim.c ****     }
 203:../Bsp/OLED/GUISlim.c ****     
 204:../Bsp/OLED/GUISlim.c ****     int non_ascii = stats.utf8_only + stats.gbk_only + stats.both_valid;
 205:../Bsp/OLED/GUISlim.c ****     if (non_ascii == 0) {
 206:../Bsp/OLED/GUISlim.c ****         return 0;     }
 207:../Bsp/OLED/GUISlim.c ****     
 208:../Bsp/OLED/GUISlim.c ****         if (stats.utf8_only > 0 && stats.gbk_invalid > stats.utf8_invalid) {
 209:../Bsp/OLED/GUISlim.c ****         return 1;     }
 210:../Bsp/OLED/GUISlim.c ****     if (stats.gbk_only > 0 && stats.utf8_invalid > stats.gbk_invalid) {
 211:../Bsp/OLED/GUISlim.c ****         return 2;     }
 212:../Bsp/OLED/GUISlim.c ****         if (stats.both_valid > 0 && stats.utf8_only == 0 && stats.gbk_only == 0) {
 213:../Bsp/OLED/GUISlim.c ****                 if (utf8_score > gbk_score) {
 214:../Bsp/OLED/GUISlim.c ****             return 1;
 215:../Bsp/OLED/GUISlim.c ****         } else if (gbk_score > utf8_score) {
 216:../Bsp/OLED/GUISlim.c ****             return 2;
 217:../Bsp/OLED/GUISlim.c ****         }
 218:../Bsp/OLED/GUISlim.c ****                 return 1;     }
 219:../Bsp/OLED/GUISlim.c ****         if (stats.utf8_only > 0 && stats.gbk_only > 0) {
 220:../Bsp/OLED/GUISlim.c ****                 int mixed_threshold = non_ascii / 5;
 221:../Bsp/OLED/GUISlim.c ****         if (stats.utf8_only > mixed_threshold && stats.gbk_only > mixed_threshold) {
ARM GAS  C:\Users\fish\AppData\Local\Temp\ccumVi9z.s 			page 19


 222:../Bsp/OLED/GUISlim.c ****             return 3;         }
 223:../Bsp/OLED/GUISlim.c ****                 if (stats.utf8_only > stats.gbk_only * 2) {
 224:../Bsp/OLED/GUISlim.c ****             return 1;
 225:../Bsp/OLED/GUISlim.c ****         } else if (stats.gbk_only > stats.utf8_only * 2) {
 226:../Bsp/OLED/GUISlim.c ****             return 2;
 227:../Bsp/OLED/GUISlim.c ****         }
 228:../Bsp/OLED/GUISlim.c ****                 return (utf8_score > gbk_score) ? 1 : 2;
 229:../Bsp/OLED/GUISlim.c ****     }
 230:../Bsp/OLED/GUISlim.c ****         if (stats.utf8_only > 0) {
 231:../Bsp/OLED/GUISlim.c ****         return 1;
 232:../Bsp/OLED/GUISlim.c ****     }
 233:../Bsp/OLED/GUISlim.c ****     if (stats.gbk_only > 0) {
 234:../Bsp/OLED/GUISlim.c ****         return 2;
 235:../Bsp/OLED/GUISlim.c ****     }
 236:../Bsp/OLED/GUISlim.c ****         if (utf8_score > gbk_score) {
 237:../Bsp/OLED/GUISlim.c ****         return 1;
 238:../Bsp/OLED/GUISlim.c ****     } else if (gbk_score > utf8_score) {
 239:../Bsp/OLED/GUISlim.c ****         return 2;
 240:../Bsp/OLED/GUISlim.c ****     }
 241:../Bsp/OLED/GUISlim.c ****     
 242:../Bsp/OLED/GUISlim.c ****     return 1; }
 243:../Bsp/OLED/GUISlim.c **** 
 244:../Bsp/OLED/GUISlim.c **** int detect_encoding_by_sequence(const char* str) {
 245:../Bsp/OLED/GUISlim.c ****     return detect_encoding_comprehensive(str);
 246:../Bsp/OLED/GUISlim.c **** }
