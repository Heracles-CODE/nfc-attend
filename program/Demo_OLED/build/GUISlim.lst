1223:../Bsp/OLED/GUISlim.c **** void GL_DrawCircle(int x0, int y0, int r) {
1224:../Bsp/OLED/GUISlim.c ****   I32 i;
1225:../Bsp/OLED/GUISlim.c ****   int imax = ((I32)((I32)r*707))/1000+1;
1226:../Bsp/OLED/GUISlim.c ****   I32 sqmax = (I32)r*(I32)r+(I32)r/2;
1227:../Bsp/OLED/GUISlim.c ****   I32 y=r;
1228:../Bsp/OLED/GUISlim.c ****   Draw8Point(x0,y0,r,0);
1229:../Bsp/OLED/GUISlim.c ****   for (i=1; i<= imax; i++) {
1230:../Bsp/OLED/GUISlim.c ****     if ((i*i+y*y) >sqmax) {
1231:../Bsp/OLED/GUISlim.c ****       Draw8Point(x0,y0,i,y);
1232:../Bsp/OLED/GUISlim.c ****       y--;
1233:../Bsp/OLED/GUISlim.c ****     }
1234:../Bsp/OLED/GUISlim.c ****     Draw8Point(x0,y0,i,y);
1235:../Bsp/OLED/GUISlim.c ****   }
1236:../Bsp/OLED/GUISlim.c **** }
1237:../Bsp/OLED/GUISlim.c **** 
