1322:../Bsp/OLED/GUISlim.c **** void GL_DrawEllipse(int x0, int y0, int rx, int ry) {
1323:../Bsp/OLED/GUISlim.c ****   I32 OutConst, Sum, SumY;
1324:../Bsp/OLED/GUISlim.c ****   int x,y;
1325:../Bsp/OLED/GUISlim.c ****   int xOld;
1326:../Bsp/OLED/GUISlim.c ****   U32 _rx = rx;
1327:../Bsp/OLED/GUISlim.c ****   U32 _ry = ry;
1328:../Bsp/OLED/GUISlim.c ****   OutConst = _rx*_rx*_ry*_ry  /* Constant as explaint above */
1329:../Bsp/OLED/GUISlim.c ****             +(_rx*_rx*_ry>>1); /* To compensate for rounding */
1330:../Bsp/OLED/GUISlim.c ****   xOld = x = rx;
1331:../Bsp/OLED/GUISlim.c ****   for (y=0; y<=ry; y++) {
1332:../Bsp/OLED/GUISlim.c ****     if (y==ry) {
1333:../Bsp/OLED/GUISlim.c ****       x=0;
1334:../Bsp/OLED/GUISlim.c ****     } else {
1335:../Bsp/OLED/GUISlim.c ****       SumY =((I32)(rx*rx))*((I32)(y*y)); /* Does not change in loop */
1336:../Bsp/OLED/GUISlim.c ****       while (Sum = SumY + ((I32)(ry*ry))*((I32)(x*x)),
1337:../Bsp/OLED/GUISlim.c ****              (x>0) && (Sum>OutConst)) x--;
1338:../Bsp/OLED/GUISlim.c ****     }
1339:../Bsp/OLED/GUISlim.c ****     /* Since we draw lines, we can not draw on the first
1340:../Bsp/OLED/GUISlim.c ****         iteration
1341:../Bsp/OLED/GUISlim.c ****     */
1342:../Bsp/OLED/GUISlim.c ****     if (y) {
