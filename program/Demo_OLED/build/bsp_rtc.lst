  33:../Bsp/RTC/bsp_rtc.c **** 
  34:../Bsp/RTC/bsp_rtc.c ****     /*
  35:../Bsp/RTC/bsp_rtc.c ****      * STM32 RTC 影子寄存器要求: 必须先读 Time 再读 Date,
  36:../Bsp/RTC/bsp_rtc.c ****      * 读取 Date 才会解锁/锁定影子寄存器, 顺序不能颠倒。
  37:../Bsp/RTC/bsp_rtc.c ****      */
  38:../Bsp/RTC/bsp_rtc.c ****     if (HAL_RTC_GetTime(&hrtc, &sTime, RTC_FORMAT_BIN) != HAL_OK)
  39:../Bsp/RTC/bsp_rtc.c ****         return HAL_ERROR;
  40:../Bsp/RTC/bsp_rtc.c ****     if (HAL_RTC_GetDate(&hrtc, &sDate, RTC_FORMAT_BIN) != HAL_OK)
  41:../Bsp/RTC/bsp_rtc.c ****         return HAL_ERROR;
  42:../Bsp/RTC/bsp_rtc.c **** 
  43:../Bsp/RTC/bsp_rtc.c ****     g_rtc_datetime.year    = 2000U + sDate.Year;
  44:../Bsp/RTC/bsp_rtc.c ****     g_rtc_datetime.month   = sDate.Month;
  45:../Bsp/RTC/bsp_rtc.c ****     g_rtc_datetime.day     = sDate.Date;
  46:../Bsp/RTC/bsp_rtc.c ****     g_rtc_datetime.hour    = sTime.Hours;
  47:../Bsp/RTC/bsp_rtc.c ****     g_rtc_datetime.minute  = sTime.Minutes;
  48:../Bsp/RTC/bsp_rtc.c ****     g_rtc_datetime.second  = sTime.Seconds;
  49:../Bsp/RTC/bsp_rtc.c ****     g_rtc_datetime.weekday = BSP_RTC_CalcWeekday(g_rtc_datetime.year,
  50:../Bsp/RTC/bsp_rtc.c ****                                                  g_rtc_datetime.month,
  51:../Bsp/RTC/bsp_rtc.c ****                                                  g_rtc_datetime.day);
  52:../Bsp/RTC/bsp_rtc.c **** 
  53:../Bsp/RTC/bsp_rtc.c ****     if (dt != NULL)
  54:../Bsp/RTC/bsp_rtc.c ****         *dt = g_rtc_datetime;
  55:../Bsp/RTC/bsp_rtc.c **** 
  56:../Bsp/RTC/bsp_rtc.c ****     return HAL_OK;
  57:../Bsp/RTC/bsp_rtc.c **** }
