 358:../Bsp/OLED/GUISlim.c **** 
 359:../Bsp/OLED/GUISlim.c **** void LCD_DrawBitmap1BPP(	int x0, int y0, int xsize, int ysize, 
 360:../Bsp/OLED/GUISlim.c **** 													int BytesPerLine, const U8 GUI_UNI_PTR * pPixel){
 361:../Bsp/OLED/GUISlim.c ****   int x1, y1;
 362:../Bsp/OLED/GUISlim.c ****   /* Handle the optional Y-magnification */
 363:../Bsp/OLED/GUISlim.c ****   y1 = y0 + ysize - 1;
 364:../Bsp/OLED/GUISlim.c ****   x1 = x0 + xsize - 1;
 365:../Bsp/OLED/GUISlim.c **** /*  Handle BITMAP without magnification */
 366:../Bsp/OLED/GUISlim.c **** 	int Diff;
 367:../Bsp/OLED/GUISlim.c **** 	/*  Clip y0 (top) */
 368:../Bsp/OLED/GUISlim.c **** 	Diff = GUI_Context.ClipRect.y0 - y0;
 369:../Bsp/OLED/GUISlim.c **** 	if (Diff > 0) {
 370:../Bsp/OLED/GUISlim.c **** 		ysize -= Diff;
 371:../Bsp/OLED/GUISlim.c **** 		if (ysize <= 0) {
 372:../Bsp/OLED/GUISlim.c **** 			return;
 373:../Bsp/OLED/GUISlim.c **** 		}
 374:../Bsp/OLED/GUISlim.c **** 		y0 = GUI_Context.ClipRect.y0;
 375:../Bsp/OLED/GUISlim.c **** 		pPixel += (unsigned)Diff * (unsigned)BytesPerLine;
 376:../Bsp/OLED/GUISlim.c **** 	}
 377:../Bsp/OLED/GUISlim.c **** 	/*  Clip y1 (bottom) */
 378:../Bsp/OLED/GUISlim.c **** 	Diff = y1 - GUI_Context.ClipRect.y1;
 379:../Bsp/OLED/GUISlim.c **** 	if (Diff > 0) {
 380:../Bsp/OLED/GUISlim.c **** 		ysize -= Diff;
 381:../Bsp/OLED/GUISlim.c **** 		if (ysize <= 0) {
 382:../Bsp/OLED/GUISlim.c **** 			return;
 383:../Bsp/OLED/GUISlim.c **** 		}
 384:../Bsp/OLED/GUISlim.c **** 	}
 385:../Bsp/OLED/GUISlim.c **** 	/*        Clip right side    */
 386:../Bsp/OLED/GUISlim.c **** 	Diff = x1 - GUI_Context.ClipRect.x1;
 387:../Bsp/OLED/GUISlim.c **** 	if (Diff > 0) {
 388:../Bsp/OLED/GUISlim.c **** 		xsize -= Diff;
 389:../Bsp/OLED/GUISlim.c **** 	}
 390:../Bsp/OLED/GUISlim.c **** 	/*        Clip left side ... (The difficult side ...)    */
 391:../Bsp/OLED/GUISlim.c **** 	Diff = 0;
 392:../Bsp/OLED/GUISlim.c **** 	if (x0 < GUI_Context.ClipRect.x0) {
 393:../Bsp/OLED/GUISlim.c **** 		Diff = GUI_Context.ClipRect.x0 - x0;
 394:../Bsp/OLED/GUISlim.c **** 		xsize -= Diff;
 395:../Bsp/OLED/GUISlim.c **** 		pPixel += (Diff>>3); 
 396:../Bsp/OLED/GUISlim.c **** 		x0 += (Diff>>3)<<3; 
 397:../Bsp/OLED/GUISlim.c **** 		Diff &=7;
 398:../Bsp/OLED/GUISlim.c **** 	}
 399:../Bsp/OLED/GUISlim.c **** 	if (xsize <=0) {
 400:../Bsp/OLED/GUISlim.c **** 		return;
 401:../Bsp/OLED/GUISlim.c **** 	}
 402:../Bsp/OLED/GUISlim.c **** 	LCD_L0_DrawBitmap1BPP(x0, y0, xsize, ysize, BytesPerLine, pPixel, Diff);
 403:../Bsp/OLED/GUISlim.c **** }
