1252:../Bsp/OLED/GUISlim.c **** void GL_FillCircle(int x0, int y0, int r) {
1253:../Bsp/OLED/GUISlim.c ****   I32 i;
1254:../Bsp/OLED/GUISlim.c ****   int imax = ((I32)((I32)r*707))/1000+1;
1255:../Bsp/OLED/GUISlim.c ****   I32 sqmax = (I32)r*(I32)r+(I32)r/2;
1256:../Bsp/OLED/GUISlim.c ****   I32 x=r;
1257:../Bsp/OLED/GUISlim.c ****   LCD_DrawHLine(x0-r,y0,x0+r);
1258:../Bsp/OLED/GUISlim.c ****   for (i=1; i<= imax; i++) {
1259:../Bsp/OLED/GUISlim.c ****     if ((i*i+x*x) >sqmax) {
1260:../Bsp/OLED/GUISlim.c ****       /* draw lines from outside */
1261:../Bsp/OLED/GUISlim.c ****       if (x>imax) {
1262:../Bsp/OLED/GUISlim.c ****         LCD_DrawHLine (x0-i+1,y0+x, x0+i-1);
1263:../Bsp/OLED/GUISlim.c ****         LCD_DrawHLine (x0-i+1,y0-x, x0+i-1);
