1287:../Bsp/OLED/GUISlim.c **** void GL_FillEllipse(int x0, int y0, int rx, int ry) {
1288:../Bsp/OLED/GUISlim.c ****   I32 OutConst, Sum, SumY;
1289:../Bsp/OLED/GUISlim.c ****   int x,y;
1290:../Bsp/OLED/GUISlim.c ****   U32 _rx = rx;
1291:../Bsp/OLED/GUISlim.c ****   U32 _ry = ry;
1292:../Bsp/OLED/GUISlim.c ****   OutConst = _rx*_rx*_ry*_ry  /* Constant as explaint above */
1293:../Bsp/OLED/GUISlim.c ****             +(_rx*_rx*_ry>>1); /* To compensate for rounding */
1294:../Bsp/OLED/GUISlim.c ****   x = rx;
1295:../Bsp/OLED/GUISlim.c ****   for (y=0; y<=ry; y++) {
1296:../Bsp/OLED/GUISlim.c ****     SumY =((I32)(rx*rx))*((I32)(y*y)); /* Does not change in loop */
1297:../Bsp/OLED/GUISlim.c ****     while (Sum = SumY + ((I32)(ry*ry))*((I32)(x*x)),
1298:../Bsp/OLED/GUISlim.c ****            (x>0) && (Sum>OutConst))
1299:../Bsp/OLED/GUISlim.c ****     {
1300:../Bsp/OLED/GUISlim.c ****       x--;
1301:../Bsp/OLED/GUISlim.c ****     }
1302:../Bsp/OLED/GUISlim.c ****     LCD_DrawHLine(x0-x, y0+y, x0+x);
1303:../Bsp/OLED/GUISlim.c ****     if (y)
1304:../Bsp/OLED/GUISlim.c ****       LCD_DrawHLine(x0-x, y0-y, x0+x);
1305:../Bsp/OLED/GUISlim.c ****   }
1306:../Bsp/OLED/GUISlim.c **** }
